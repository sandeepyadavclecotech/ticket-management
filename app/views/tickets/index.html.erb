<%= render "shared/navbar"%>
<% if notice%>
  <p class="text-success mt-3"><%= notice%></p>
<%end%>
<div class="text-center">
  <%if current_customer.admin?%>
    <p class="mt-3" >admin: <%= current_customer.email%></p>
  <%else%>
    <p class="mt-3">customer: <%= current_customer.email%></p>
  <%end%>
</div>
<div class="box">
  <div class="card1">
    <div class="row1">
      <p>Total Tickets</p>
      <i class="fa-solid fa-user-group"></i>
    </div>
    <div class="row2">
      <b><%= @totalTickets%></b>
    </div>
  </div>
  <div class="card1">
    <div class="row1">
      <p>Open Tickets</p>
      <i class="fa-solid fa-spinner text-danger "></i>
    </div>
    <div class="row2">
      <b><%= @openedTickets%></b>
    </div>
  </div>
  <div class="card1">
    <div class="row1">
      <p>In-Progress Tickets</p>
      <i class="fa-regular fa-clock text-warning"></i>
    </div>
    <div class="row2">
      <b><%= @inProgressTickets%></b>
    </div>
  </div>
  <div class="card1">
    <div class="row1">
      <p>Closed Tickets</p>
      <i class="fa-regular fa-circle-check text-success"></i>
    </div>
    <div class="row2">
      <b><%= @closedTickets%></b>
    </div>
  </div>
</div>
<%if @tickets.count == 0%>
  <div  class="d-flex flex-column align-items-center justify-content-center">
    <h2 class="error-text">Ticket not found !!</h2>
    <%= link_to "Raise new ticket", new_ticket_path, class: "btn btn-primary mt-3 mb-4 "%>
  </div>
<%else%>
  <h2 class="text-center  mt-2 mb-4"> Tickets</h2>
  <div class="container">
    <table class="table table-bordered">
      <thead>
        <tr>
          <th>Ticket No.</th>
          <th>Title</th>
          <th>Status</th>
          <th>Priority</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% @tickets.each do |ticket| %>
          <tr>
            <td><%= ticket.ticket_number %></td>
            <td><%= ticket.title %></td>
            <%if ticket.status == "Closed"%>
              <td class="text-danger"><%= ticket.status %></td>
            <%elsif ticket.status == "In-Progress"%>
              <td class="text-warning"><%= ticket.status %></td>
            <%else%>
              <td class="text-success"><%= ticket.status %></td>
            <%end%>
            <td><%= ticket.priority %></td>
            <td>
              <div class="btn-group">
                <button
              type="button"
              class="btn btn-primary dropdown-toggle"
              data-bs-toggle="dropdown"
              aria-expanded="false">
                  Action
                </button>
                <ul class="dropdown-menu">
                  <li>
                    <%= link_to "Show", ticket_path(ticket), class: "dropdown-item" %>
                  </li>
                  <li>
                    <%= link_to "Edit", edit_ticket_path(ticket), class: "dropdown-item" %>
                  </li>
                  <li>
                    <%= button_to "Delete",
                            ticket_path(ticket),
                            method: :delete,
                            data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
                            class: "dropdown-item text-danger" %>
                  </li>
                </ul>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<%end%>
