<%= render "shared/navbar"%>
<% if notice%>
  <p class="text-success"><%= notice%></p>
<%end%>
<%if current_customer.subscribed? || current_customer.admin?%>
  <h2 class="text-center text-success mt-3 mb-4"> Tickets Summary</h2>
  <div class="container">
    <table class="table table-bordered">
      <thead>
        <tr>
          <th>Total Tickets</th>
          <th>Opened Tickets</th>
          <th>In Progress Tickets</th>
          <th>Closed Tickets</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><%= @totalTickets %></td>
          <td><%= @openedTickets %></td>
          <td><%= @inProgressTickets %></td>
          <td><%= @closedTickets %></td>
        </tr>
      </tbody>
    </table>
  </div>
<%else%>
  <div class="container text-center mt-5">
    <h2 class=" mt-4">Please <span class="text-primary">Subscribe</span>  to Access Summary !!</h2>
    <%= link_to "Subscribe" , subscription_path, class: "btn btn-outline-primary mt-3 " %>
  </div>
<%end%>
