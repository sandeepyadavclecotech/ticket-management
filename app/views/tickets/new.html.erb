<%= render "shared/navbar"%>
<% if @ticket.errors.any? %>
  <div class="alert alert-danger">
    <ul>
      <% @ticket.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>
<%if current_customer.subscribed?%>
  <%=render "tickets/form"%>
<%else%>
  <div class="text-center mt-5">
    <h2>Please <span class="text-primary">Subscribe</span>  to Raise New Ticket !!</h2>
    <%= link_to "Subscribe" , subscription_path, class: "btn btn-outline-primary mt-3 " %>
  </div>
<%end%>
