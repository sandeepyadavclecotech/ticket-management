<h2 class="text-center text-success mt-3">Forgot your password?</h2>
<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>
  <div class="container mt-3">
    <div class="field row">
      <div class="col-6">
        <p><%= f.label :email , class: "form-label"%></p>
        <p><%= f.email_field :email, autofocus: true, autocomplete: "email" , class: "form-control"%></p>
      </div>
    </div>
    <div class="actions">
      <%= f.submit "Send me password reset instructions" %>
    </div>
  </div>
<% end %>
<div class="container">
  <div class="row">
    <div class="col-6 mt-3">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
